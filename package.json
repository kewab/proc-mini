    "@icebreakers/stylelint-config": "^2.2.1",
    "@iconify-json/mdi": "^1.2.3",
    "autoprefixer": "^10.4.27",
    "eslint": "^10.1.0",
    "miniprogram-api-typings": "^5.1.2",
    "postcss": "^8.5.8",
    "sass": "^1.98.0",
    "stylelint": "^17.6.0",
    "tailwindcss": "3.4.19",
    "typescript": "^6.0.2",
    "vue-tsc": "^3.2.6",
    "weapp-tailwindcss": "^4.11.2",
    "weapp-vite": "^6.14.3",
    "wevu": "^6.14.3"
